#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

usage() {
  cat <<EOF
Usage: ./run <command>

Commands:
  relay          Build and start the relay node
  web            Start the web app dev server
  electron       Start the Electron desktop app in dev mode (optional profile name)
  android-sync   Build web assets and sync into Capacitor Android project
  android-open   Open Android Studio for the Capacitor Android project
  android-build-apk Build debug APK via Gradle
  relay-docker-build Build Docker image for anypost-relay
  electron-appimage Build Linux x86_64 Electron AppImage (incremental)
  electron-appimage-fresh Build a fresh Linux x86_64 Electron AppImage
  electron-win   Build Windows x86_64 Electron Portable EXE (incremental)
  electron-win-fresh Build a fresh Windows x86_64 Electron Portable EXE
  electron-mac   Build macOS x64 DMG+ZIP (incremental, run on macOS host)
  electron-mac-fresh Build a fresh macOS x64 DMG+ZIP (run on macOS host)
  dev            Start both relay and web app (Ctrl+C stops both)
  e2e-record     Run headless Chromium Alice/Bob scenario + download diagnostics logs
  e2e-dm-refresh Run headless Chromium DM refresh continuity integration test
  e2e-soak       Run repeated headless DM no-relay browser integration test
  build          Build all packages
  test           Run all tests
  typecheck      Type-check all packages
EOF
}

cmd_relay() {
  echo "Building relay..."
  pnpm --filter anypost-relay build
  echo "Starting relay..."
  pnpm --filter anypost-relay start
}

cmd_web() {
  trap 'kill 0; wait' EXIT INT TERM

  echo "Building anypost-core..."
  pnpm --filter anypost-core build

  echo "Watching anypost-core for changes..."
  pnpm --filter anypost-core build --watch &

  echo "Starting web dev server..."
  # Use vite directly here to avoid running any predev hooks twice.
  pnpm --filter anypost-web exec vite &

  wait
}

cmd_electron() {
  shift || true
  local profile="${1:-}"
  if [[ -n "$profile" ]]; then
    shift || true
    ANYPOST_PROFILE="$profile" pnpm --filter anypost-electron run dev -- --profile "$profile" "$@"
  else
    pnpm --filter anypost-electron run dev -- "$@"
  fi
}

cmd_android_sync() {
  pnpm --filter anypost-android run sync
}

cmd_android_open() {
  pnpm --filter anypost-android run open
}

cmd_android_build_apk() {
  pnpm --filter anypost-android run build:apk
}

cmd_relay_docker_build() {
  docker build \
    --file apps/anypost-relay/Dockerfile \
    --tag anypost-relay:local \
    .
  echo "Built image: anypost-relay:local"
}

clear_dir_if_exists() {
  local dir="$1"
  if [[ ! -d "$dir" ]]; then
    return 0
  fi
  find "$dir" -mindepth 1 -delete
  rmdir "$dir" 2>/dev/null || true
}

package_electron_appimage() {
  echo "Prebuilding anypost-core..."
  pnpm --filter anypost-core build

  echo "Building Electron app..."
  pnpm --filter anypost-electron build

  mkdir -p "$SCRIPT_DIR/apps/anypost-electron/release"
  find "$SCRIPT_DIR/apps/anypost-electron/release" -maxdepth 1 -type f -name '*.AppImage' -delete

  echo "Packaging Linux x86_64 AppImage..."
  pnpm --filter anypost-electron exec electron-builder \
    --projectDir . \
    --config electron-builder.yml \
    --linux AppImage \
    --x64 \
    --publish never \
    --config.directories.output=release

  echo "AppImage ready:"
  ls -1 apps/anypost-electron/release/*.AppImage
}

cmd_electron_appimage() {
  package_electron_appimage
}

cmd_electron_appimage_fresh() {
  echo "Cleaning previous build artifacts..."
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-electron/dist"
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-electron/release"
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-web/dist"
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-relay/dist"
  clear_dir_if_exists "$SCRIPT_DIR/packages/anypost-core/dist"
  package_electron_appimage
}

package_electron_windows() {
  echo "Prebuilding anypost-core..."
  pnpm --filter anypost-core build

  echo "Building Electron app..."
  pnpm --filter anypost-electron build

  mkdir -p "$SCRIPT_DIR/apps/anypost-electron/release"
  find "$SCRIPT_DIR/apps/anypost-electron/release" -maxdepth 1 -type f -name '*win*.exe' -delete
  find "$SCRIPT_DIR/apps/anypost-electron/release" -maxdepth 1 -type f -name '*.exe' -delete
  find "$SCRIPT_DIR/apps/anypost-electron/release" -maxdepth 1 -type f -name '*.blockmap' -delete
  find "$SCRIPT_DIR/apps/anypost-electron/release" -maxdepth 1 -type f -name 'latest*.yml' -delete

  echo "Packaging Windows x86_64 Portable EXE..."
  pnpm --filter anypost-electron exec electron-builder \
    --projectDir . \
    --config electron-builder.yml \
    --win portable \
    --x64 \
    --publish never \
    --config.directories.output=release

  echo "Windows build ready:"
  ls -1 apps/anypost-electron/release/*.exe
}

cmd_electron_win() {
  package_electron_windows
}

cmd_electron_win_fresh() {
  echo "Cleaning previous build artifacts..."
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-electron/dist"
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-electron/release"
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-web/dist"
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-relay/dist"
  clear_dir_if_exists "$SCRIPT_DIR/packages/anypost-core/dist"
  package_electron_windows
}

package_electron_macos() {
  echo "Prebuilding anypost-core..."
  pnpm --filter anypost-core build

  echo "Building Electron app..."
  pnpm --filter anypost-electron build

  mkdir -p "$SCRIPT_DIR/apps/anypost-electron/release"
  find "$SCRIPT_DIR/apps/anypost-electron/release" -maxdepth 1 -type f -name '*.dmg' -delete
  find "$SCRIPT_DIR/apps/anypost-electron/release" -maxdepth 1 -type f -name '*mac*.zip' -delete
  find "$SCRIPT_DIR/apps/anypost-electron/release" -maxdepth 1 -type f -name '*.blockmap' -delete
  find "$SCRIPT_DIR/apps/anypost-electron/release" -maxdepth 1 -type f -name 'latest*.yml' -delete

  echo "Packaging macOS x64 DMG + ZIP..."
  CSC_IDENTITY_AUTO_DISCOVERY=false pnpm --filter anypost-electron exec electron-builder \
    --projectDir . \
    --config electron-builder.yml \
    --mac dmg zip \
    --x64 \
    --publish never \
    --config.directories.output=release

  echo "macOS build ready:"
  ls -1 apps/anypost-electron/release/*.dmg apps/anypost-electron/release/*mac*.zip
}

cmd_electron_mac() {
  package_electron_macos
}

cmd_electron_mac_fresh() {
  echo "Cleaning previous build artifacts..."
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-electron/dist"
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-electron/release"
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-web/dist"
  clear_dir_if_exists "$SCRIPT_DIR/apps/anypost-relay/dist"
  clear_dir_if_exists "$SCRIPT_DIR/packages/anypost-core/dist"
  package_electron_macos
}

cmd_dev() {
  trap 'kill 0; wait' EXIT INT TERM

  echo "Building anypost-core..."
  pnpm --filter anypost-core build

  echo "Watching anypost-core for changes..."
  pnpm --filter anypost-core build --watch &

  echo "Building relay..."
  pnpm --filter anypost-relay build

  echo "Starting relay..."
  pnpm --filter anypost-relay start &

  # Give the relay a moment to print its multiaddr
  sleep 2

  echo ""
  echo "Starting web dev server..."
  # Use vite directly here to avoid running any predev hooks twice.
  pnpm --filter anypost-web exec vite &

  wait
}

cmd_build() {
  pnpm run build
}

cmd_test() {
  pnpm run test
}

cmd_typecheck() {
  pnpm run typecheck
}

cmd_e2e_record() {
  shift || true
  pnpm --filter anypost-web run e2e:record -- "$@"
}

cmd_e2e_dm_refresh() {
  shift || true
  pnpm --filter anypost-web run e2e:dm-refresh-ipfs -- "$@"
}

cmd_e2e_soak() {
  shift || true
  pnpm --filter anypost-web run e2e:soak -- "$@"
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "$1" in
  relay)     cmd_relay ;;
  web)       cmd_web ;;
  electron)  cmd_electron "$@" ;;
  android-sync) cmd_android_sync ;;
  android-open) cmd_android_open ;;
  android-build-apk) cmd_android_build_apk ;;
  relay-docker-build) cmd_relay_docker_build ;;
  electron-appimage) cmd_electron_appimage ;;
  electron-appimage-fresh) cmd_electron_appimage_fresh ;;
  electron-win) cmd_electron_win ;;
  electron-win-fresh) cmd_electron_win_fresh ;;
  electron-mac) cmd_electron_mac ;;
  electron-mac-fresh) cmd_electron_mac_fresh ;;
  dev)       cmd_dev ;;
  e2e-record) cmd_e2e_record "$@" ;;
  e2e-dm-refresh) cmd_e2e_dm_refresh "$@" ;;
  e2e-soak)  cmd_e2e_soak "$@" ;;
  build)     cmd_build ;;
  test)      cmd_test ;;
  typecheck) cmd_typecheck ;;
  *)
    echo "Unknown command: $1"
    usage
    exit 1
    ;;
esac
