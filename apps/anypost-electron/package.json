{
  "name": "anypost-electron",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "build:main": "tsc --project tsconfig.json",
    "build": "pnpm --filter anypost-core build && pnpm --filter anypost-web build && pnpm --filter anypost-relay build && pnpm run build:main && node ./scripts/copy-web-dist.mjs",
    "start": "electron ./dist/main/main.js",
    "test": "node -e \"console.log('No electron tests yet')\"",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "anypost-core": "workspace:*",
    "anypost-relay": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "electron": "^32.2.0",
    "electron-builder": "24.13.3"
  }
}
