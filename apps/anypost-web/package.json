{
  "name": "anypost-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter anypost-core build",
    "dev": "vite",
    "build": "pnpm --filter anypost-core build && vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "e2e:record": "node ./scripts/e2e-headless-recording.mjs",
    "e2e:dm-no-relay-ipfs": "node ./scripts/e2e-dm-no-relay-ipfs.mjs",
    "e2e:dm-call-convergence-ipfs": "node ./scripts/e2e-dm-call-convergence-ipfs.mjs",
    "e2e:dm-refresh-ipfs": "node ./scripts/e2e-dm-refresh-ipfs.mjs",
    "e2e:soak": "node ./scripts/e2e-soak.mjs"
  },
  "dependencies": {
    "anypost-core": "workspace:*",
    "d3-force": "^3.0.0",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/d3-force": "^3.0.10",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.0",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10"
  }
}
